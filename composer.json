{
  "name": "sitepulse/sst-laravel",
  "description": "Deploy robust, auto-scalable Laravel applications to AWS Fargate using SST and Docker",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/console": "^10.0|^11.0|^12.0",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "symfony/process": "^6.0|^7.0"
  },
  "autoload": {
    "psr-4": {
      "Sitepulse\\SST\\": "laravel"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Sitepulse\\SST\\SstLaravelServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
