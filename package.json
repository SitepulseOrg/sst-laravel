{
  "name": "@sitepulse/sst-laravel",
  "version": "0.3.8",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "description": "An unofficial extension of SST to deploy containerized Laravel applications to AWS Fargate.",
  "main": "laravel-sst.ts",
  "types": "laravel-sst.ts",
  "exports": {
    ".": {
      "types": "./laravel-sst.ts",
      "import": "./laravel-sst.ts"
    },
    "./runtime": {
      "types": "./runtime.d.ts",
      "import": "./runtime.js",
      "default": "./runtime.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/bin",
    "src",
    "laravel-sst.ts",
    "runtime.js",
    "runtime.d.ts",
    "sst-env.d.ts",
    "templates",
    "conf",
    "images",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "Dockerfile.web",
    "Dockerfile.worker",
    ".dockerignore",
    "skills"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "release": "./scripts/publish.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sitepulse/sst-laravel.git"
  },
  "keywords": [
    "laravel",
    "sst",
    "aws",
    "serverless"
  ],
  "author": {
    "name": "Luis Dalmolin",
    "email": "luis@sitepulse.dev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/sitepulse/sst-laravel/issues"
  },
  "homepage": "https://github.com/sitepulse/sst-laravel#readme",
  "bin": {
    "sst-laravel": "dist/bin/cli.js"
  },
  "dependencies": {
    "@aws-sdk/client-ecs": "^3.0.0",
    "@aws-sdk/client-iam": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-sts": "^3.0.0",
    "@inquirer/prompts": "^7.0.0",
    "@pulumi/aws": "^7.8.0",
    "@pulumi/pulumi": "^3.203.0",
    "commander": "^12.0.0",
    "sst": "^4.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
