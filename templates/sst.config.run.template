    const { LaravelService, RemoteEnvVault } = await import("@sitepulse/sst-laravel");
    const vpc = new sst.aws.Vpc("MyVpc");
    // you can also use an existing VPC
    // const vpc = sst.aws.Vpc.get("DefaultVpc", "vpc-12345678901234567");

    const database = new sst.aws.Postgres('MyDB', { vpc });

    /**
     * With RemoteEnvVault, SST-Laravel will use the environment variables stored in the remote vault (AWS Secrets Manager)
     * This makes it easy to manage env with teams, and especially makes it ready for CI/CD
     * 
     * To get started, create the environment file first, and push it to the remote vault. Examples:
     * - `cp .env.example .env.dev`
     * - `php artisan key:generate --env .env.dev`
     * - `pnpm exec sst-laravel env:push --stage dev`
     * 
     * Replace `dev` with the stage you want to set up
     */
    const env = new RemoteEnvVault("Env");

    const app = new LaravelService("MyLaravelApp", {
      vpc,
      link: [database],

      config: {
        php: 8.4,
        environment: {
          secrets: env,
        },
        deployment: {
          script: 'infra/deploy.sh',
        },
      },

      web: {
        domain: {
          // if your domain is managed via Route53 in the same account, SST will handle the DNS for you
          // you can also use Cloudflare DNS (see https://sst.dev/docs/component/cloudflare/dns/)
          // you can also manually configure DNS. Check all "domain" options in "loadBalancer.domain" here: https://sst.dev/docs/component/aws/service/#loadbalancer-domain.
          // dns: false,

          // if you don't provide a domain name, you will be able to use the load balancer domain for testing (http only)
          name: $app.stage === "production"
            ? "example.com"
            : `${$app.stage}.example.com`,
        }
      },

      // this configuration will create a dedicated Reverb container for WebSocket traffic
      // reverb: {
      //   domain: {
      //     name: $app.stage === "production"
      //       ? "ws.example.com"
      //       : `ws.${$app.stage}.example.com`,
      //   },
      // },

      // this configuration will create one worker container, which will run horizon and the laravel scheduler as background jobs
      workers: [
        {
          horizon: true,
          scheduler: true,
        }
      ]
    });

    return {
      url: app.url,
      // reverbUrl: app.reverbUrl,
    };
